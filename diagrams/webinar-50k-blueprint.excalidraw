    {
      "type": "text", "id": "mission-sub", "x": 550, "y": 115, "width": 2100, "height": 120,
      "text": "OFFER: $997 Predictable Patient Pipeline Program  |  UPSELL: $5K/month Agency (4-month min = $20K LTV)\nSCHEDULE: Every Thursday 7 PM ET (auto-rolling)  |  HOST: Dr. Emeka — HealthProCEO\nTARGET: 7 sales/webinar + 1-2 agency upsells = $12,000+/week  |  AD BUDGET: $7,000/month",
      "fontSize": 20, "fontFamily": 1, "textAlign": "center", "verticalAlign": "top",
