    {
      "type": "text", "id": "w5-text", "x": 1660, "y": 1470, "width": 360, "height": 220,
      "text": "PART 4: THE STACK — 15 min\n\nPresent $997 offer:\n• Value stack: $18,154\n• Live bonuses (Sun deadline)\n• 3 payment option: $397 × 3\n• ROI math on screen\n\nPART 5: Q&A + CLOSE — 20 min\n\nHandle objections live:\n• \"Not tech-savvy\" → click-by-click\n• \"Tried ads before\" → system ≠ random\n• \"Can I hire you?\" → /apply\n• Deadline reminder: Sunday midnight",
      "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "PART 4: THE STACK — 15 min\n\nPresent $997 offer:\n• Value stack: $18,154\n• Live bonuses (Sun deadline)\n• 3 payment option: $397 × 3\n• ROI math on screen\n\nPART 5: Q&A + CLOSE — 20 min\n\nHandle objections live:\n• \"Not tech-savvy\" → click-by-click\n• \"Tried ads before\" → system ≠ random\n• \"Can I hire you?\" → /apply\n• Deadline reminder: Sunday midnight",
      "autoResize": true, "lineHeight": 1.25,
