    {"type":"text","id":"nurture-text","x":520,"y":1190,"width":860,"height":360,"text":"PRE-WEBINAR NURTURE SEQUENCE\nTag: webinar-registered\n\nIMMEDIATELY → SMS + Email confirmation\nWED 10AM → Day-before reminder (SMS + Email)\nTHU 9AM → 'Today's the day!' (SMS)\nTHU 6PM → '60 minutes!' + Zoom link (SMS)\nTHU 6:30PM → Join link email\nTHU 7PM → 'We're LIVE!' (SMS)\nTHU 7:05PM → No-show nudge (SMS)\n\nGoal: 45%+ show-up rate","fontSize":18,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","containerId":"nurture-box","originalText":"PRE-WEBINAR NURTURE SEQUENCE\nTag: webinar-registered\n\nIMMEDIATELY → SMS + Email confirmation\nWED 10AM → Day-before reminder (SMS + Email)\nTHU 9AM → 'Today's the day!' (SMS)\nTHU 6PM → '60 minutes!' + Zoom link (SMS)\nTHU 6:30PM → Join link email\nTHU 7PM → 'We're LIVE!' (SMS)\nTHU 7:05PM → No-show nudge (SMS)\n\nGoal: 45%+ show-up rate","autoResize":true,"lineHeight":1.25,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"strokeColor":"#1e1e1e","backgroundColor":"transparent","isDeleted":false,"angle":0,"seed":41,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},

