    {
      "type": "text", "id": "revenue-content", "x": 70, "y": 210, "width": 480, "height": 250,
      "text": "175 registrants x $10 CPR = $1,750 ad spend\nx 40% show rate = 70 attendees\nx 10% conversion = 7 sales\nx $997 = $6,979/webinar\n\n+ Replay sales: ~$2,000-3,000\n+ Agency upsell: 1-2 x $5K/month\n\n= $50K+/MONTH (by Month 2)\n\nMonthly ad budget: $4,000-7,000\nTarget ROAS: 5-8x",
      "fontSize": 16, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "175 registrants x $10 CPR = $1,750 ad spend\nx 40% show rate = 70 attendees\nx 10% conversion = 7 sales\nx $997 = $6,979/webinar\n\n+ Replay sales: ~$2,000-3,000\n+ Agency upsell: 1-2 x $5K/month\n\n= $50K+/MONTH (by Month 2)\n\nMonthly ad budget: $4,000-7,000\nTarget ROAS: 5-8x",
      "autoResize": true, "lineHeight": 1.25,
      "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
