    {"type":"text","id":"attendee-text","x":70,"y":2140,"width":1010,"height":360,"text":"ATTENDEE FOLLOW-UP SEQUENCE\nTag: webinar-attended\n\nTHU 8:30PM → Scaling Roadmap + offer link\nFRI 10AM → Case study deep dive\nSAT 10AM → Social proof + objections\nSUN 10AM → 'Last day' deadline\nSUN 6PM → '6 hours left'\nSUN 9PM → '3 hours' final email\nSUN 11PM → '1 hour left'","fontSize":18,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","containerId":"attendee-box","originalText":"ATTENDEE FOLLOW-UP SEQUENCE\nTag: webinar-attended\n\nTHU 8:30PM → Scaling Roadmap + offer link\nFRI 10AM → Case study deep dive\nSAT 10AM → Social proof + objections\nSUN 10AM → 'Last day' deadline\nSUN 6PM → '6 hours left'\nSUN 9PM → '3 hours' final email\nSUN 11PM → '1 hour left'","autoResize":true,"lineHeight":1.25,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"strokeColor":"#1e1e1e","backgroundColor":"transparent","isDeleted":false,"angle":0,"seed":61,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},

